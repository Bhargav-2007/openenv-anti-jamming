        """
        if self.done:
            raise RuntimeError("Episode is done. Call reset() first.")
        
        self.current_step += 1
        
        # ═══════════════════════════════════════════════════════════
        # STEP 1: Agent transmits with chosen parameters
        # ═══════════════════════════════════════════════════════════
        
        freq_ch = action.frequency_channel
