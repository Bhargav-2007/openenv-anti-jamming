# 7. Training Your Own Agent (Advanced)

## 7.1. Simple RL Training with Stable-Baselines3

Create `train_rl_agent.py`:

```python
"""
Train RL agent using Stable-Baselines3
Requires: pip install stable-baselines3 gymnasium
"""

import asyncio
import gymnasium as gym
import numpy as np
from stable_baselines3 import PPO
from stable_baselines3.common.vec_env import DummyVecEnv

from anti_jamming_env import AntiJammingEnv, AntiJammingAction


class GymWrapper(gym.Env):
    """Wrap async OpenEnv as sync Gym environment."""
    
    def __init__(self, task="easy"):
        super().__init__()
        self.env = AntiJammingEnv(task=task, max_steps=50)
        
        # Define spaces
        # Action: [freq_ch, tx_power, modulation_idx, coding_idx, beam, fhss, dsss, notch]
        self.action_space = gym.spaces.Box(
            low=np.array([0, 0, 0, 0, 0, 0, 0, 0]),
            high=np.array([63, 30, 3, 3, 7, 1, 1, 1]),
            dtype=np.float32
        )
        
        # Observation: simplified to key metrics
        self.observation_space = gym.spaces.Box(
            low=-np.inf,
            high=np.inf,
            shape=(32,),  # Channel states + metrics
            dtype=np.float32
        )
    
    def reset(self, seed=None, options=None):
        result = asyncio.run(self.env.reset())
        obs = self._extract_obs(result.observation)
        return obs, {}
    
    def step(self, action):
        # Convert continuous action to discrete action
        aj_action = self._decode_action(action)
        result = asyncio.run(self.env.step(aj_action))
        
        obs = self._extract_obs(result.observation)
        reward = result.reward
        done = result.done
        truncated = False
        info = result.info
        
        return obs, reward, done, truncated, info
    
    def _extract_obs(self, observation):
        """Extract flat observation vector."""
        obs_vec = []
        
        # Channel states (16 channels * 2 = 32 features)
        for ch in observation.channel_states:
            obs_vec.append(ch.sinr_db / 30.0)  # Normalize
            obs_vec.append(float(ch.is_jammed))
        
        return np.array(obs_vec, dtype=np.float32)
    
    def _decode_action(self, action):
        """Convert continuous action to AntiJammingAction."""
        modulations = ["BPSK", "QPSK", "16QAM", "64QAM"]
        coding_rates = ["1/2", "2/3", "3/4", "5/6"]
        
        return AntiJammingAction(
            frequency_channel=int(action[0]) % 64,
            tx_power_dbm=float(np.clip(action[1], 0, 30)),
            modulation=modulations[int(action[2]) % 4],
            coding_rate=coding_rates[int(action[3]) % 4],
            beam_direction=int(action[4]) % 8,
            enable_fhss=bool(action[5] > 0.5),
            enable_dsss=bool(action[6] > 0.5),
            enable_notch_filter=bool(action[7] > 0.5)
        )


if __name__ == "__main__":
    # Create environment
    env = DummyVecEnv([lambda: GymWrapper(task="easy")])
    
    # Create PPO agent
    model = PPO(
        "MlpPolicy",
        env,
        verbose=1,
        learning_rate=3e-4,
        n_steps=2048,
        batch_size=64,
        n_epochs=10,
        gamma=0.99,
        gae_lambda=0.95,
        clip_range=0.2,
        ent_coef=0.01,
    )
    
    # Train
    print("Training PPO agent...")
    model.learn(total_timesteps=100_000)
    
    # Save
    model.save("anti_jamming_ppo")
    print("Model saved to anti_jamming_ppo.zip")
    
    # Evaluate
    print("\nEvaluating trained agent...")
    obs = env.reset()
    total_reward = 0
    for _ in range(50):
        action, _ = model.predict(obs, deterministic=True)
        obs, reward, done, info = env.step(action)
        total_reward += reward[0]
        if done[0]:
            break
    
    print(f"Evaluation Total Reward: {total_reward:.2f}")
```

