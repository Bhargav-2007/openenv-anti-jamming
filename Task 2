API_BASE_URL = os.getenv("API_BASE_URL") or "https://router.huggingface.co/v1"
MODEL_NAME = os.getenv("MODEL_NAME") or "Qwen/Qwen2.5-72B-Instruct"

# ←←← ANTI-JAMMING: Task configuration
TASK_NAME = os.getenv("ANTI_JAMMING_TASK", "easy")
BENCHMARK = os.getenv("ANTI_JAMMING_BENCHMARK", "anti_jamming_comm")

MAX_STEPS = 50
TEMPERATURE = 0.7
MAX_TOKENS = 200
SUCCESS_SCORE_THRESHOLD = 0.5  # Normalized score in [0, 1]

# ←←← ANTI-JAMMING: Max possible reward per step
# Successful transmission: ~1.0, throughput bonus: ~0.5, total ~1.5 per step
_MAX_REWARD_PER_STEP = 2.0
MAX_TOTAL_REWARD = MAX_STEPS * _MAX_REWARD_PER_STEP


# ═══════════════════════════════════════════════════════════════════
# SYSTEM PROMPT (instructs LLM on the anti-jamming task)
# ═══════════════════════════════════════════════════════════════════

SYSTEM_PROMPT = textwrap.dedent(
    """
    You are controlling a wireless transmitter in an anti-jamming communication system.
    
    Your goal: Maintain reliable communication while under attack from an intelligent jammer.
    
    Each turn, you must select transmission parameters:
    - Frequency channel (0-63): Which frequency to use
    - Transmit power (0-30 dBm): How much power to transmit
    - Modulation (BPSK/QPSK/16QAM/64QAM): Data encoding scheme
    - Coding rate (1/2, 2/3, 3/4, 5/6): Error correction strength
    - Beam direction (0-7): Spatial selectivity
    - Anti-jamming techniques (FHSS, DSSS, notch filters)
    
    Strategy tips:
    - Jammer attacks certain frequencies → hop to clean channels
    - Higher modulation = more throughput but needs better SINR
    - Lower coding rate = more robust but less throughput
    - Use FHSS/DSSS to spread signal and avoid jamming
    - Balance throughput vs. energy consumption
    
    Respond with a valid JSON object containing your action parameters.
    Example:
    {
      "frequency_channel": 15,
      "tx_power_dbm": 20.0,
      "modulation": "QPSK",
      "coding_rate": "2/3",
      "beam_direction": 3,
      "enable_fhss": true,
      "enable_dsss": false,
      "enable_notch_filter": false
    }
    """
).strip()


# ═══════════════════════════════════════════════════════════════════
# LOGGING FUNCTIONS (required format)
# ═══════════════════════════════════════════════════════════════════

def log_start(task: str, env: str, model: str) -> None:
    """Log episode start."""
    print(f"[START] task={task} env={env} model={model}", flush=True)


def log_step(step: int, action: str, reward: float, done: bool, error: Optional[str]) -> None:
    """Log each step."""
    error_val = error if error else "null"
    done_val = str(done).lower()
    print(
        f"[STEP] step={step} action={action} reward={reward:.2f} done={done_val} error={error_val}",
        flush=True,
    )


def log_end(success: bool, steps: int, score: float, rewards: List[float]) -> None:
    """Log episode end."""
    rewards_str = ",".join(f"{r:.2f}" for r in rewards)
    print(
        f"[END] success={str(success).lower()} steps={steps} score={score:.3f} rewards={rewards_str}",
        flush=True
    )


# ═══════════════════════════════════════════════════════════════════
# PROMPT BUILDING
# ═══════════════════════════════════════════════════════════════════

def build_user_prompt(
    step: int,
    observation: Any,
    last_reward: float,
    history: List[str]
) -> str:
    """
    Build user prompt from current observation.
    
    ←←← ANTI-JAMMING: Formats spectrum sensing data for LLM
    """
    obs = observation
    
    # Format channel states (show top channels by SINR)
    channel_info_lines = []
    for ch_state in obs.channel_states[:8]:  # Top 8 for brevity
        status = "🔴 JAMMED" if ch_state.is_jammed else "🟢 CLEAR"
        channel_info_lines.append(
            f"  Ch {ch_state.frequency_index:2d}: SINR={ch_state.sinr_db:+6.1f} dB, "
            f"SNR={ch_state.snr_db:+6.1f} dB, PER={ch_state.packet_error_rate:.2%} {status}"
        )
    
    channel_info = "\n".join(channel_info_lines)
    
    # Jammer intelligence
    jammer_info = (
        f"Jammer Type: {obs.jammer_state.detected_jammer_type}\n"
        f"Jammer Power: {obs.jammer_state.jammer_power_dbm:.1f} dBm\n"
        f"Attack Pattern: {obs.jammer_state.attack_pattern}"
    )
    
    # Recent performance
    perf_info = (
        f"Last TX: {'✓ Success' if obs.last_transmission_success else '✗ Failed'}\n"
        f"Last SINR: {obs.last_sinr_db:+.1f} dB\n"
        f"Last Throughput: {obs.last_throughput_mbps:.2f} Mbps\n"
        f"Recent Success Rate: {obs.recent_success_rate:.1%} (last 5 steps)"
    )
    
    # History summary
    history_block = "\n".join(history[-3:]) if history else "None"
    
    prompt = textwrap.dedent(
        f"""
        === STEP {step} / {MAX_STEPS} ===
        
        Task: {obs.task_description}
        
        SPECTRUM ANALYSIS:
        {channel_info}
        
        JAMMER INTELLIGENCE:
        {jammer_info}
        
        PERFORMANCE:
        {perf_info}
        Last Reward: {last_reward:+.2f}
        
        RECENT HISTORY:
        {history_block}
        
        Select your next transmission parameters as JSON.
        """
    ).strip()
    
    return prompt


# ═══════════════════════════════════════════════════════════════════
# LLM INTERACTION
# ═══════════════════════════════════════════════════════════════════

def get_model_action(
    client: OpenAI,
    step: int,
    observation: Any,
    last_reward: float,
    history: List[str]
) -> AntiJammingAction:
    """
    Get action from LLM.
    
    ←←← ANTI-JAMMING: Parses JSON response into typed action
    """
    user_prompt = build_user_prompt(step, observation, last_reward, history)
    
    try:
        completion = client.chat.completions.create(
            model=MODEL_NAME,
            messages=[
                {"role": "system", "content": SYSTEM_PROMPT},
                {"role": "user", "content": user_prompt},
            ],
            temperature=TEMPERATURE,
            max_tokens=MAX_TOKENS,
            stream=False,
        )
        
        text = (completion.choices[0].message.content or "").strip()
        
        # Parse JSON response
        # Clean markdown code blocks if present
        if "```json" in text:
            text = text.split("```json")[1].split("```")[0].strip()
        elif "```" in text:
            text = text.split("```")[1].split("```")[0].strip()
        
        action_dict = json.loads(text)
        
        # Create typed action
        action = AntiJammingAction(**action_dict)
        
        return action
        
    except Exception as exc:
        print(f"[DEBUG] Model request failed: {exc}", flush=True)
        print(f"[DEBUG] Raw response: {text if 'text' in locals() else 'N/A'}", flush=True)
        
        # ←←← ANTI-JAMMING: Fallback to safe default action
        return AntiJammingAction(
            frequency_channel=32,  # Middle channel
            tx_power_dbm=15.0,     # Medium power
            modulation="QPSK",     # Moderate modulation
            coding_rate="2/3",     # Balanced coding
            beam_direction=0,
            enable_fhss=True,      # Use frequency hopping by default
            enable_dsss=False,
            enable_notch_filter=False
        )


# ═══════════════════════════════════════════════════════════════════
# MAIN INFERENCE LOOP
# ═══════════════════════════════════════════════════════════════════

async def main() -> None:
    """
    Main inference loop.
    
    ←←← ANTI-JAMMING: Follows exact same structure as original MyEnvV4 example
    """
    client = OpenAI(base_url=API_BASE_URL, api_key=API_KEY)
    
    # ←←← ANTI-JAMMING: Create environment (local or from Docker)
    if IMAGE_NAME:
        env = await AntiJammingEnv.from_docker_image(IMAGE_NAME, task=TASK_NAME)
    else:
        env = AntiJammingEnv(task=TASK_NAME, max_steps=MAX_STEPS)
    
    history: List[str] = []
    rewards: List[float] = []
    steps_taken = 0
    score = 0.0
    success = False
    
    log_start(task=TASK_NAME, env=BENCHMARK, model=MODEL_NAME)
    
    try:
        # ═══════════════════════════════════════════════════════════
        # RESET ENVIRONMENT
        # ═══════════════════════════════════════════════════════════
        
        result = await env.reset()
        observation = result.observation
        last_reward = 0.0
        
        # ═══════════════════════════════════════════════════════════
        # EPISODE LOOP
        # ═══════════════════════════════════════════════════════════
        
        for step in range(1, MAX_STEPS + 1):
            if result.done:
                break
            
            # Get action from LLM
            action = get_model_action(client, step, observation, last_reward, history)
            
            # Format action for logging
            action_str = (
                f"freq={action.frequency_channel},pwr={action.tx_power_dbm:.1f},"
                f"mod={action.modulation},fhss={action.enable_fhss}"
            )
            
            # Execute action
            result = await env.step(action)
            observation = result.observation
            
            reward = result.reward or 0.0
            done = result.done
            error = None  # No error handling in base version
            
            rewards.append(reward)
            steps_taken = step
            last_reward = reward
            
            # Log step
            log_step(step=step, action=action_str, reward=reward, done=done, error=error)
            
            # Update history
            tx_status = "✓" if observation.last_transmission_success else "✗"
            history.append(
                f"Step {step}: Ch{action.frequency_channel} "
                f"{action.modulation} {tx_status} → reward {reward:+.2f}"
            )
            
            if done:
                break
        
        # ═══════════════════════════════════════════════════════════
        # CALCULATE FINAL SCORE
        # ═══════════════════════════════════════════════════════════
        
        # Get final state and grade
        from anti_jamming_env.graders import grade_episode
        from anti_jamming_env.tasks import TASKS
        
        final_state = env.state()
        task_config = TASKS[TASK_NAME]
        grading_result = grade_episode(final_state, task_config)
        
        score = grading_result["score"]
        success = grading_result["success"]
        
        # Print grading feedback
        print(f"\n[GRADING]\n{grading_result['feedback']}\n", flush=True)
    
    except Exception as e:
        print(f"[ERROR] Episode failed: {e}", flush=True)
        import traceback
        traceback.print_exc()
    
    finally:
        # ═══════════════════════════════════════════════════════════
        # CLEANUP AND LOG END
        # ═══════════════════════════════════════════════════════════
        
        try:
            await env.close()
        except Exception as e:
            print(f"[DEBUG] env.close() error: {e}", flush=True)
        
        log_end(success=success, steps=steps_taken, score=score, rewards=rewards)


if __name__ == "__main__":
    asyncio.run(main())
