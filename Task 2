"""
Heuristic Agent
Simple rule-based agent that performs basic frequency hopping
"""

import asyncio
from anti_jamming_env import AntiJammingEnv, AntiJammingAction


async def heuristic_agent(task: str = "easy"):
    """
    Simple heuristic strategy:
    - Hop to channel with best SINR
    - Use moderate power (15 dBm)
    - Use QPSK with 2/3 coding
    - Enable FHSS always
    """
    
    env = AntiJammingEnv(task=task, max_steps=50)
    
    print(f"Running Heuristic Agent on task: {task}")
    print("="*60)
    
    result = await env.reset()
    total_reward = 0.0
    
    for step in range(50):
        if result.done:
            break
        
        obs = result.observation
        
        # Select channel with best SINR
        best_channel = max(
            obs.channel_states,
            key=lambda ch: ch.sinr_db
        )
        
        # Heuristic action
        action = AntiJammingAction(
            frequency_channel=best_channel.frequency_index,
            tx_power_dbm=15.0,  # Moderate power
            modulation="QPSK",  # Robust modulation
            coding_rate="2/3",  # Balanced coding
            beam_direction=0,
            enable_fhss=True,   # Always use frequency hopping
            enable_dsss=False,
            enable_notch_filter=obs.jammer_state.jammer_power_dbm > 20  # Use notch if strong jammer
        )
        
        result = await env.step(action)
        total_reward += result.reward
        
        if (step + 1) % 10 == 0:
            success_symbol = "✓" if result.observation.last_transmission_success else "✗"
            print(f"Step {step + 1}: {success_symbol} Ch{action.frequency_channel} "
                  f"SINR={result.observation.last_sinr_db:+.1f}dB "
                  f"Reward={result.reward:+.2f}")
    
    # Final grading
    from anti_jamming_env.graders import grade_episode
    from anti_jamming_env.tasks import TASKS
    
    final_state = env.state()
    grading = grade_episode(final_state, TASKS[task])
    
    print("\n" + "="*60)
    print("Heuristic Agent Results:")
    print(f"  Total Reward: {total_reward:.2f}")
    print(f"  Final Score: {grading['score']:.3f}")
    print(f"  Success: {grading['success']}")
    print(f"  Success Rate: {grading['metrics']['success_rate']:.1%}")
    print("="*60)
    
    await env.close()


if __name__ == "__main__":
    import sys
    task = sys.argv[1] if len(sys.argv) > 1 else "easy"
    asyncio.run(heuristic_agent(task=task))
