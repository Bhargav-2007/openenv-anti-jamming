## 🤖 Training an Agent

### Option 1: Stable-Baselines3 (RL)

```python
import asyncio
from stable_baselines3 import PPO
from stable_baselines3.common.env_util import make_vec_env
from anti_jamming_env import AntiJammingEnv

# Create vectorized environment
def make_env():
    def _init():
        # Convert async env to sync wrapper
        import gymnasium as gym
        class SyncWrapper(gym.Env):
            def __init__(self):
                self.env = AntiJammingEnv(task="easy")
                # Define spaces...
            
            def reset(self):
                result = asyncio.run(self.env.reset())
                return result.observation, {}
            
            def step(self, action):
                result = asyncio.run(self.env.step(action))
                return (
                    result.observation,
                    result.reward,
                    result.done,
                    False,
                    result.info
                )
        
        return SyncWrapper()
    return _init

vec_env = make_vec_env(make_env, n_envs=4)

# Train PPO agent
model = PPO("MlpPolicy", vec_env, verbose=1)
model.learn(total_timesteps=100000)
model.save("anti_jamming_ppo")

# Evaluate
obs = vec_env.reset()
for _ in range(1000):
    action, _ = model.predict(obs, deterministic=True)
    obs, reward, done, info = vec_env.step(action)
```

