"""
Grading Logic for Anti-Jamming Tasks
Deterministic graders that score agent performance from 0.0 to 1.0
"""

import numpy as np
from typing import Dict, List, Any
from anti_jamming_env.models import AntiJammingState
from anti_jamming_env.tasks import TaskConfig, TASKS


def grade_episode(
    final_state: AntiJammingState,
    task_config: TaskConfig
) -> Dict[str, Any]:
    """
    Grade a completed episode.
    
    Returns a score from 0.0 to 1.0 based on task-specific criteria.
    
    Args:
        final_state: Complete state at end of episode
        task_config: Task configuration with grading weights
    
    Returns:
        Dict with:
            - score: float [0, 1]
            - success: bool (score >= threshold)
            - breakdown: Dict of component scores
            - feedback: str with performance summary
    """
    
    # Extract metrics from state
    total_steps = final_state.current_step
    successful_tx = final_state.successful_transmissions
    failed_tx = final_state.failed_transmissions
    total_throughput = final_state.cumulative_throughput
    total_energy = final_state.cumulative_energy
    
    # Avoid division by zero
    total_tx = successful_tx + failed_tx
    if total_tx == 0:
        total_tx = 1
    
    # ═══════════════════════════════════════════════════════════════
    # COMPONENT 1: Throughput Score
    # ═══════════════════════════════════════════════════════════════
    
    # Normalize throughput (ideal: ~50 Mbps * 50 steps = 2500 total)
    max_possible_throughput = 50.0 * total_steps  # Ideal case
    throughput_score = min(total_throughput / max_possible_throughput, 1.0)
    
    # ═══════════════════════════════════════════════════════════════
    # COMPONENT 2: Success Rate Score
    # ═══════════════════════════════════════════════════════════════
    
    success_rate = successful_tx / total_tx
    success_rate_score = success_rate
    
    # ═══════════════════════════════════════════════════════════════
    # COMPONENT 3: Energy Efficiency Score
    # ═══════════════════════════════════════════════════════════════
    
    # Energy efficiency = throughput / energy
    # Good efficiency: > 1.0 Mbps/mJ
    if total_energy > 0:
        efficiency = total_throughput / total_energy
        efficiency_score = min(efficiency / 10.0, 1.0)  # Normalize
    else:
        efficiency_score = 0.0
    
    # ═══════════════════════════════════════════════════════════════
    # COMPONENT 4: SINR Quality Score
    # ═══════════════════════════════════════════════════════════════
    
    # Average SINR from full spectrum
    avg_sinr = np.mean(final_state.full_channel_snr)
    # Good SINR: > 15 dB
    sinr_score = min(max(avg_sinr / 20.0, 0.0), 1.0)
    
    # ═══════════════════════════════════════════════════════════════
    # COMPONENT 5: Adaptation Score (medium/hard tasks)
    # ═══════════════════════════════════════════════════════════════
    
    adaptation_score = 0.0
    if "adaptation" in task_config.grading_weights:
        # Measure frequency diversity (how many different channels used)
        channels_used = set()
        for action in final_state.action_history:
            channels_used.add(action.get("frequency_channel", 0))
        
        # Good adaptation: use at least 10 different channels
        adaptation_score = min(len(channels_used) / 10.0, 1.0)
    
    # ═══════════════════════════════════════════════════════════════
    # COMPONENT 6: Unpredictability Score (hard task)
    # ═══════════════════════════════════════════════════════════════
    
    unpredictability_score = 0.0
    if "unpredictability" in task_config.grading_weights:
        # Measure entropy of frequency selection
        if final_state.action_history:
            freq_sequence = [
                action.get("frequency_channel", 0) 
                for action in final_state.action_history
            ]
            
            # Calculate transition entropy
            transitions = {}
            for i in range(len(freq_sequence) - 1):
                pair = (freq_sequence[i], freq_sequence[i+1])
                transitions[pair] = transitions.get(pair, 0) + 1
            
            # Shannon entropy
            total_transitions = sum(transitions.values())
            if total_transitions > 0:
                entropy = 0.0
                for count in transitions.values():
                    p = count / total_transitions
                    entropy -= p * np.log2(p + 1e-10)
                
                # Normalize entropy (max ~6 bits for 64 channels)
                unpredictability_score = min(entropy / 6.0, 1.0)
    
    # ═══════════════════════════════════════════════════════════════
    # WEIGHTED FINAL SCORE
    # ═══════════════════════════════════════════════════════════════
    
    component_scores = {
        "throughput": throughput_score,
        "success_rate": success_rate_score,
        "energy_efficiency": efficiency_score,
        "sinr_quality": sinr_score,
    }
    
    if "adaptation" in task_config.grading_weights:
        component_scores["adaptation"] = adaptation_score
    
    if "unpredictability" in task_config.grading_weights:
        component_scores["unpredictability"] = unpredictability_score
    
    # Calculate weighted score
    final_score = 0.0
    for component, weight in task_config.grading_weights.items():
        final_score += component_scores.get(component, 0.0) * weight
    
    # Clamp to [0, 1]
    final_score = max(0.0, min(1.0, final_score))
    
    # Success determination
    success = final_score >= task_config.success_threshold
    
    # ═══════════════════════════════════════════════════════════════
    # FEEDBACK GENERATION
    # ═══════════════════════════════════════════════════════════════
    
    feedback_lines = [
        f"Task: {task_config.name.upper()} ({task_config.difficulty})",
        f"Final Score: {final_score:.3f} / 1.000",
        f"Success: {success} (threshold: {task_config.success_threshold:.2f})",
        "",
        "Performance Breakdown:",
        f"  • Throughput: {total_throughput:.1f} Mbps (score: {throughput_score:.3f})",
        f"  • Success Rate: {success_rate:.1%} ({successful_tx}/{total_tx}) (score: {success_rate_score:.3f})",
        f"  • Energy Efficiency: {total_throughput/max(total_energy, 0.1):.2f} Mbps/mJ (score: {efficiency_score:.3f})",
        f"  • SINR Quality: {avg_sinr:.1f} dB (score: {sinr_score:.3f})",
    ]
    
    if "adaptation" in component_scores:
        feedback_lines.append(
            f"  • Adaptation: {len(channels_used)} unique channels (score: {adaptation_score:.3f})"
        )
    
    if "unpredictability" in component_scores:
        feedback_lines.append(
            f"  • Unpredictability: entropy {entropy:.2f} bits (score: {unpredictability_score:.3f})"
        )
    
    feedback = "\n".join(feedback_lines)
    
    return {
        "score": round(final_score, 3),
        "success": success,
        "breakdown": component_scores,
        "feedback": feedback,
        "metrics": {
            "total_throughput_mbps": round(total_throughput, 2),
            "success_rate": round(success_rate, 3),
            "successful_transmissions": successful_tx,
            "failed_transmissions": failed_tx,
            "total_energy_mj": round(total_energy, 2),
            "avg_sinr_db": round(avg_sinr, 2),
        }
    }


def quick_grade(
    successful_tx: int,
    failed_tx: int,
    task_name: str = "easy"
) -> float:
    """
    Quick grading based on success rate only.
    Useful for rapid evaluation.
    
    Returns:
        Score in [0, 1]
    """
    total_tx = successful_tx + failed_tx
    if total_tx == 0:
        return 0.0
    
    success_rate = successful_tx / total_tx
    
    # Simple threshold-based scoring
    task_config = TASKS[task_name]
    if success_rate >= task_config.success_threshold:
        return success_rate
    else:
        return success_rate * 0.7  # Penalty for below threshold
